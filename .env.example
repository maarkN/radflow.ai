# --- Infra (docker compose) ---
POSTGRES_USER=radflow
POSTGRES_PASSWORD=radflow
POSTGRES_DB=radflow
POSTGRES_PORT=5434

NATS_PORT=4222
NATS_MONITOR_PORT=8222

ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9091
GRAFANA_PORT=3300
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Services ---
NODE_ENV=development
API_GATEWAY_PORT=3010
WORKLIST_PORT=3001
INTEGRATION_PORT=3002
DICTATION_PORT=3003
REPORT_AI_PORT=8000

DATABASE_URL=postgresql://radflow:radflow@localhost:5434/radflow
NATS_URL=nats://localhost:4222
ORTHANC_URL=http://localhost:8042

# --- AI providers (report-ai) ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
