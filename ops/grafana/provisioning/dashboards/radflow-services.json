{
  "uid": "radflow-services",
  "title": "RadFlow — Services (RED)",
  "tags": ["radflow"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by service (spans/s)",
      "datasource": { "type": "prometheus", "uid": null },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(radflow_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate by service (spans/s)",
      "datasource": { "type": "prometheus", "uid": null },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(radflow_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p95 by service",
      "datasource": { "type": "prometheus", "uid": null },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(radflow_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Top operations by rate",
      "datasource": { "type": "prometheus", "uid": null },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "topk(10, sum by (service_name, span_name) (rate(radflow_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "{{service_name}} {{span_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
